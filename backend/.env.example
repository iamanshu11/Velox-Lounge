# Server
PORT=5004
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dragonpass_db
DB_USER=postgres
DB_PASSWORD=password
DB_SSL=false

# JWT
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3004

# DragonPass API (future)
DRAGONPASS_API_BASE_URL=https://api.dragonpass.com/v1
DRAGONPASS_API_KEY=
DRAGONPASS_CLIENT_ID=
DRAGONPASS_CLIENT_SECRET=

# Email (future)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@dragonpass.com
